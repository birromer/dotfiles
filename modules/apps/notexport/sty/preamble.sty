\RequirePackage[backend=biber,
                style=alphabetic,
                doi=true,
                hyperref=true,
                maxcitenames=2,
                maxbibnames=99,
                giveninits=true,
                isbn=false,
                url=true,
                eprint=false,
                sorting=nty,
                backref=true,
                backrefstyle=three
               ]{biblatex}

\setlength\bibitemsep{0.5\baselineskip}

\DeclareFieldFormat{doi}{%
  \ifhyperref
    {\href{https://doi.org/#1}{\nolinkurl{doi:#1}}}
    {\nolinkurl{doi:#1}}}

\renewbibmacro{in:}{%
  \ifentrytype{article}{}{\printtext{\bibstring{in}\intitlepunct}}}

% CLEANUP CONFIGURATION
\AtEveryBibitem{
  \clearfield{month}
  \clearfield{day}
  \clearfield{note}
  \clearfield{issn}
  \clearfield{pages}
  \clearfield{pagetotal}
  \clearfield{series}
  \clearfield{number}
  \clearfield{pubstate}   % Removes "Pre-published"
  \clearfield{urlyear}    % Removes "visited on" year
  \clearfield{urldate}    % Removes "visited on" completely
  \clearname{editor}      % Removes "Ed. by..."
  \clearlist{location}
  \clearlist{publisher}

  \ifentrytype{online}{
      % Always keep URL for online entries
  }{
      \iffieldundef{doi}{
          % No DOI? Keep the URL.
      }{
          % Has DOI? Clear the URL to avoid redundancy.
          \clearfield{url}
      }
  }
}

\addbibresource{./refs.bib}

