% ================================== Headers ===================================
\ifpreamble@root
\else
  \RequirePackage{fancyhdr}
  \renewcommand{\maketitle}{ % Redefine make title command
    \thispagestyle{empty}
    \begin{center}
      \textbf{\huge \textsc{\@title}}\\
      \vspace{2ex}
      \large \@author\\
      \vspace{1ex}
      \itshape \normalsize \textcolor{dark_yellow}{Compiled: \@date}\\
    \end{center}
  }
  \pagestyle{fancy}
  \renewcommand{\headrulewidth}{0pt}

  \fancyhead[L]{\parbox[t]{0.30\linewidth}
  {\link{000-contents}[\texttt{\jobname}]}}
  \fancyhead[C]{\parbox[t]{0.65\linewidth}
  {\centering\textsc{\@title}}}
  \fancyhead[R]{\textcolor{dark_yellow}{\texttt{\@date}}}
  \renewcommand{\headrulewidth}{0pt}

  \AtBeginDocument{
    \maketitle
    \tableofcontents
  }
\fi

