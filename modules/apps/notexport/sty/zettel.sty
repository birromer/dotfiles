% ==================== Gettings and parsing string options ====================
\RequirePackage{kvoptions}
\SetupKeyvalOptions{
  family=zettel,
  prefix=zettel@
}
% Set knowledge mode: 'draft', 'print' and 'digital'

\DeclareStringOption[draft]{mode}
\DeclareBoolOption[false]{displayids}
\ProcessKeyvalOptions*

\IfEqCase{\zettel@mode}{
  {draft}{\def\knowledgepackagemode{composition}}
  {print}{\def\knowledgepackagemode{paper}}
  {digital}{\def\knowledgepackagemode{electronic}}
}

% =========================== Knowledge management ============================
\usepackage{sty/colors}
\usepackage{mathcommand}
\usepackage[makeidx]{knowledge} % Must be loaded after cleveref

\knowledgeconfigure{notion, quotation}
\knowledgeconfigure{protect quotation={tikzcd}}
\knowledgeconfigure{diagnose line=true}

\ifzettel@displayids
  \newcommand{\leftmarginnote}[2][0pt]{%
    \marginpar{\raisebox{#1}[0pt][0pt]{%
        \parbox[t]{3cm}{\hspace{40pt}\raggedright\textcolor{cCite}{\texttt{#2}}}%
    }}%
  }
  \reversemarginpar
\else
  \newcommand{\leftmarginnote}[2][0pt]{
    %
  }
\fi

\IfKnowledgePaperModeTF{
  \knowledgestyle{intro notion}{color={cNotion}, emphasize}
  \knowledgestyle{notion}{color={cNotion}}
  %
}{
  % If we are NOT in paper mode (i.e. in composition mode or electronic mode)
%  \knowledgestyle{intro notion}{color={cIntro}, emphasize}
  \knowledgestyle{intro notion}{color={cNotion}, emphasize}
  \knowledgestyle{notion}{color={cNotion}}
  \hypersetup{
      colorlinks=true,
      breaklinks=true,
      linkcolor={cLink}, % Links to sections, pages, etc.
      citecolor={cCite}, % Links to bibliography
      filecolor={cFile}, % Links to local file
      urlcolor={cUrl},
  }
  \IfKnowledgeElectronicModeTF{
      %
  }{
    % If we are in composition mode, highlight unknown stuff (in yellow) and display the anchor point.
    \knowledgestyle{intro notion}{color={cIntro}, emphasize}
    \knowledgestyle{notion}{color={cNotion}}
    \knowledgeconfigure{anchor point color={cIntro}, anchor point shape=corner}
    \knowledgestyle{intro unknown}{color={cUndefined}, emphasize}
    \knowledgestyle{intro unknown cont}{color={cUndefined}, emphasize}
    \knowledgestyle{kl unknown}{color={cUndefined}}
    \knowledgestyle{kl unknown cont}{color={cUndefined}}
  }
}

% ========================= Define minimum knowledge ==========================
% The notes environment defines a knowledge per entry. The item's content is 
% the filename, and it goes automatically to the index.
\newcommandx{\addnote}[2][2='']{
  \knowledge{#1}[#2]{url=file:#1.pdf,color=ForestGreen,index=:#1@\kl{#1}}
}

